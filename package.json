{
  "name": "@basetime/a2w-webview-ts",
  "version": "0.2.2",
  "description": "SDK for embedded apps running inside the atw scanner webview.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.js",
      "default": "./build/index.js"
    },
    "./react": {
      "types": "./build/react/index.d.ts",
      "import": "./build/react/index.js",
      "require": "./build/react/index.js",
      "default": "./build/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "react": [
        "./build/react/index.d.ts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf build",
    "build": "pnpm tsc",
    "watch": "pnpm tsc --watch --preserveWatchOutput",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "postpublish": "pnpm build && ./upload-build.sh"
  },
  "keywords": [],
  "author": "Avagate Inc.",
  "license": "UNLICENSED",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jest/types": "^29.6.3",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^17.0.39",
    "@types/react": "^18.3.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jsdoc": "^48.2.2",
    "fetch-mock": "^11.1.1",
    "jest": "^29.7.0",
    "react": "^18.3.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@basetime/a2w-api-ts": "^0.1.49"
  }
}
